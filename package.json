{
  "name": "@podman-desktop/eslint-plugin",
  "version": "0.3.0-next",
  "description": "ESLint plugin with rules for Podman Desktop",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/podman-desktop/eslint-plugin"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "lint:check": "eslint .",
    "lint:fix": "pnpm run build && eslint --fix .",
    "format:check": "biome format",
    "format:fix": "biome format --write",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/eslint": "^9.6.0",
    "@types/node": "^24",
    "eslint": "^10.0.0",
    "eslint-plugin-yml": "^3.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,tsx,jsx,yml,yaml}": [
      "eslint --fix",
      "biome format --write"
    ]
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
